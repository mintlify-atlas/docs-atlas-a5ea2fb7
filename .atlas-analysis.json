  "keyFeatures": [
    "Cross-platform Rust emulator core with C ABI",
    "Native Android app (Kotlin + Jetpack Compose)",
    "Native iOS app (Swift + SwiftUI)",
    "Web app (React + TypeScript + WASM)",
    "Dual backend design (Rust + CEmu reference)",
    "Full eZ80 CPU emulation with ADL mode",
    "320x240 LCD with 16-bit color",
    "Cycle-accurate peripheral emulation",
    "Save/restore state support",
    "TI-84 CE program loading (.8xp/.8xv)"
  ],
  "publicApiSurface": [
    "emu_create() - Create emulator instance",
    "emu_destroy() - Destroy emulator",
    "emu_load_rom() - Load ROM data",
    "emu_send_file() - Inject .8xp/.8xv files",
    "emu_power_on() - Start emulation",
    "emu_run_cycles() - Execute cycles",
    "emu_framebuffer() - Get display buffer",
    "emu_set_key() - Handle input",
    "emu_save_state() - Serialize state",
    "emu_load_state() - Deserialize state",
    "emu_is_lcd_on() - Check LCD status",
    "emu_get_backlight() - Get brightness",
    "emu_reset() - Reset emulator",
    "Emu::new() - Rust constructor",
    "Emu::load_rom() - Rust ROM loading",
    "Emu::run_cycles() - Rust execution",
    "EmulatorBackend - TypeScript interface"
  ]
